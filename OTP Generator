import java.util.Random;
import java.util.Scanner;
public class OtpGenerator {
    static void main() {
        Scanner sc = new Scanner(System.in);
        StringBuilder sb = new StringBuilder();
        Random rand = new Random();
        System.out.print("How many digits of OTP you want: ");
        int n = sc.nextInt();
        int[] arr = new int[n];
        for(int i =0; i<n;i++){
            arr[i] = rand.nextInt(0,9);
            String str = Integer.toString(arr[i]);
            sb.append(str);
        }
        System.out.println(sb);
        System.out.print("Entre the otp for the verification: ");
        int num = sc.nextInt();
        String ptr = sb.toString();
        int num1 = Integer.parseInt(ptr);
        if (num == num1){
            System.out.print("you are verified");
            return;
        }
        else {
            System.out.println("your are not verified!!!");
            main();
            return;
        }
    }
}
